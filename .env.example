# Get your OpenRouter API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
# Model for book extraction (defaults to ultra-affordable gpt-4o-mini with big context window)
OPENROUTER_MODEL=openai/gpt-4o-mini
# Model for podcast audio transcription (uses OpenRouter audio-capable chat models)
OPENROUTER_AUDIO_MODEL=openai/gpt-audio-mini
# Port (optional, defaults to 3000)
PORT=3000